<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="iut.gon.bomberman.client.controllers.OnlineGameController"
      style="-fx-background-color: #1a1a2e;">

    <Canvas fx:id="gameCanvas" width="800" height="800" />

    <VBox fx:id="chatPanel"
          prefWidth="250"
          style="-fx-background-color: #0f0f1a; -fx-border-color: #2244aa; -fx-border-width: 0 0 0 2;">

        <Label text="Chat"
               style="-fx-text-fill: #4488ff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 12 8 12; -fx-border-color: #2244aa; -fx-border-width: 0 0 1 0;" />

        <ScrollPane fx:id="chatScrollPane"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background: #0f0f1a; -fx-background-color: #0f0f1a;">
            <VBox fx:id="chatMessages" spacing="3"
                  style="-fx-padding: 6; -fx-background-color: #0f0f1a;" />
        </ScrollPane>

        <VBox spacing="6" style="-fx-padding: 8; -fx-border-color: #2244aa; -fx-border-width: 1 0 0 0;">
            <TextField fx:id="chatInput"
                       promptText="Ecrire un message..."
                       style="-fx-background-color: #1a1a2e; -fx-text-fill: white; -fx-prompt-text-fill: #666688; -fx-border-color: #334499; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 12px; -fx-padding: 5 8 5 8;" />
            <Button fx:id="sendButton"
                    text="Envoyer"
                    onAction="#onSendButtonClicked"
                    style="-fx-background-color: #2244aa; -fx-text-fill: white; -fx-font-size: 12px; -fx-cursor: hand; -fx-background-radius: 4; -fx-padding: 5 10 5 10;" />
        </VBox>
    </VBox>

</HBox>